# ──────────────────────────────────────────────
# VeloCal — Docker Compose Environment Variables
# ──────────────────────────────────────────────
# Copy this file to .env and fill in production values:
#   cp .env.example .env
#
# All variables with defaults are optional.
# Variables marked REQUIRED have no safe default.

# ── Database ──────────────────────────────────
DB_PASSWORD=velocal

# ── Backend ───────────────────────────────────
# REQUIRED — generate with: openssl rand -base64 32
JWT_SECRET=not-secret
JWT_EXPIRATION=7d

# Admin seed credentials (created on first boot)
ADMIN_EMAIL=admin@invalid.email
ADMIN_PASSWORD=12notsecret34

# Minutes between allowed import triggers
IMPORT_COOLDOWN_MINUTES=5

# Race Result import: country codes (comma-separated)
# 276 = Germany, 528 = Netherlands
RACE_RESULT_COUNTRIES=276,528

# ── Ports (host:container mapping) ────────────
FRONTEND_PORT=80
BACKEND_PORT=3000
